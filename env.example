# ============================================================
#  Taxi Jipijapa — Variables de entorno / Secretos
# ============================================================
#
#  Copia este archivo a `.env` y rellena los valores reales.
#  NUNCA subas `.env` a Git.
#
# -------- Google Maps ----------------------------------------
GOOGLE_MAPS_API_KEY=AIza...

# -------- Firebase (solo si la CLI no configura automáticamente) ---
# Estos valores ya están en google-services.json / GoogleService-Info.plist
# y en firebase_options.dart generado por FlutterFire CLI.
# FIREBASE_API_KEY=...
# FIREBASE_APP_ID=...

# -------- Firma de APK (se configuran como GitHub Secrets) ----
# KEYSTORE_BASE64=<base64 del archivo .jks>
# KEY_ALIAS=upload
# KEY_PASSWORD=****
# STORE_PASSWORD=****

# -------- Firebase Deploy (GitHub Actions) --------------------
# FIREBASE_TOKEN=<token de firebase login:ci>

# ============================================================
#  Cómo usar:
#
#  Desarrollo local:
#    flutter run --dart-define=GOOGLE_MAPS_API_KEY=$GOOGLE_MAPS_API_KEY
#
#  Android: agrega en android/local.properties (ya está en .gitignore):
#    GOOGLE_MAPS_API_KEY=AIza...
#
#  iOS: copia ios/Flutter/Secrets.xcconfig.example → Secrets.xcconfig
#    GOOGLE_MAPS_API_KEY=AIza...
#
#  CI/CD: configurar como GitHub repository secrets.
# ============================================================
