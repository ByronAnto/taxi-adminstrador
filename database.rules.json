{
  "rules": {
    ".read": false,
    ".write": false,

    "channelLocks": {
      "$associationId": {
        ".read": "auth != null && auth.token.associationId === $associationId",

        "$channelId": {
          ".write": "auth != null && auth.token.associationId === $associationId && (!data.exists() || data.child('uid').val() === auth.uid || (now - data.child('since').val()) > 35000 || auth.token.role === 'admin' || auth.token.role === 'operadora')",

          ".validate": "newData.hasChildren(['uid', 'name', 'since'])",

          "uid": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "name": {
            ".validate": "newData.isString() && newData.val().length <= 120"
          },
          "since": {
            ".validate": "newData.val() === now"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },

    "presence": {
      "$associationId": {
        ".read": "auth != null && auth.token.associationId === $associationId && (auth.token.role === 'admin' || auth.token.role === 'operadora')",

        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.token.associationId === $associationId && (auth.uid === $uid || auth.token.role === 'admin' || auth.token.role === 'operadora')",

          ".validate": "newData.hasChild('online') && newData.hasChild('updatedAt')",

          "online": {
            ".validate": "newData.isBoolean()"
          },
          "lat": {
            ".validate": "newData.isNumber()"
          },
          "lng": {
            ".validate": "newData.isNumber()"
          },
          "speed": {
            ".validate": "newData.isNumber()"
          },
          "heading": {
            ".validate": "newData.isNumber()"
          },
          "accuracy": {
            ".validate": "newData.isNumber()"
          },
          "stationary": {
            ".validate": "newData.isBoolean()"
          },
          "status": {
            ".validate": "newData.isString() && newData.val().length <= 40"
          },
          "driverId": {
            ".validate": "newData.isString() && newData.val().length <= 128"
          },
          "updatedAt": {
            ".validate": "newData.val() === now"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    }
  }
}
