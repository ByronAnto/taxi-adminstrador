rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPERS BÁSICOS =====

    function isAuthenticated() {
      return request.auth != null;
    }

    // Lee del JWT (custom claim sincronizado por el trigger syncUserClaims).
    // Si por alguna razón no estuviera presente, devuelve cadena vacía.
    function getRole() {
      return isAuthenticated() ? request.auth.token.get('role', '') : '';
    }

    function getStatus() {
      return isAuthenticated() ? request.auth.token.get('status', '') : '';
    }

    function isActive() {
      return isAuthenticated() && getStatus() == 'active';
    }

    /// Conductor que está bloqueado por mora pero puede subir comprobante
    /// para reactivarse. Es el único caso donde un usuario "no active"
    /// puede escribir documentos (solamente pagos propios).
    function canPayWhileBlocked() {
      return isAuthenticated() && getStatus() == 'paymentBlocked';
    }

    /// Cubre tanto active como paymentBlocked (para acciones de pago).
    function canSubmitPayment() {
      return isActive() || canPayWhileBlocked();
    }

    /// Operación normal: active O paymentPending (banner de aviso pero
    /// todavía no bloqueado). Los `paymentBlocked` y `disabledByAdmin` NO
    /// pueden hablar/enviar nada en el canal — están en modo solo pago.
    /// Útil para acciones operativas día-a-día (chat, walkie-talkie,
    /// asignar carreras) donde no queremos congelar la operación por un
    /// banner de pago.
    function canOperate() {
      return isAuthenticated()
        && (getStatus() == 'active' || getStatus() == 'paymentPending');
    }

    function isAdmin() {
      return isActive() && getRole() == 'admin';
    }

    function isOperatorOrAdmin() {
      return isActive() && getRole() in ['admin', 'operadora'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Super-admin del SaaS. Se reconoce por email O por custom claim.
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'brealpeaymara@gmail.com'
        || request.auth.token.get('superAdmin', false) == true
      );
    }

    // Slug de la asociación a la que pertenece el caller (custom claim).
    function myAssociationId() {
      return isAuthenticated() ? request.auth.token.get('associationId', '') : '';
    }

    // Compatibilidad con docs legacy sin associationId: se asumen 'jipijapa'
    // (la primera asociación del SaaS, antes de la migración multi-tenant).
    function docTenant(data) {
      return data.get('associationId', 'jipijapa');
    }

    // ¿El doc pertenece al tenant del caller? Super-admin pasa siempre.
    function sameTenant(data) {
      return isSuperAdmin() || docTenant(data) == myAssociationId();
    }

    // ¿El payload entrante declara el tenant del caller?
    function sameTenantOnCreate() {
      return isSuperAdmin()
        || request.resource.data.get('associationId', '') == myAssociationId();
    }

    // ===== PTT LOCK (walkie-talkie) =====

    function pttLockExpired(data) {
      return !('speakerLockedAt' in data) || data.speakerLockedAt == null
        || request.time > data.speakerLockedAt + duration.value(35, 's');
    }

    function pttLockAvailable(data) {
      return !('currentSpeakerId' in data) || data.currentSpeakerId == null
        || data.currentSpeakerId == ''
        || pttLockExpired(data);
    }

    // ===== ASOCIACIONES (SaaS multi-tenant) =====
    // Lectura pública SOLO de asociaciones activas/trial: necesario
    // para el selector de cooperativa en el registro del cliente web,
    // que aún no está autenticado. El resto requiere auth + match de
    // tenant.
    match /associations/{aid} {
      allow read: if isSuperAdmin()
        || (isAuthenticated() && myAssociationId() == aid)
        || resource.data.get('status', '') in ['active', 'trial'];
      allow write: if isSuperAdmin();
    }

    // ===== PLANES DE PRECIOS =====
    // Lectura abierta a autenticados (admins necesitan ver planes).
    match /pricingTiers/{tid} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ===== USUARIOS =====
    // - Cada uno SIEMPRE puede leer/actualizar su propio doc (necesario
    //   para PendingApprovalPage incluso cuando aún no está activo).
    // - El resto del listado solo se ve dentro del mismo tenant.
    // - Crear: solo el propio uid (registro).
    // - Borrar: admin del mismo tenant o super-admin.
    match /users/{userId} {
      allow read: if isOwner(userId)
        || isSuperAdmin()
        || (isActive() && sameTenant(resource.data));

      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && (
          isSuperAdmin()
          || request.resource.data.get('associationId', '') != ''
        );

      allow update: if isOwner(userId)
        || isSuperAdmin()
        || (isAdmin() && sameTenant(resource.data));

      allow delete: if isSuperAdmin()
        || (isAdmin() && sameTenant(resource.data));
    }

    // ===== CONDUCTORES =====
    match /drivers/{driverId} {
      allow read: if canOperate() && sameTenant(resource.data);
      allow create: if isOperatorOrAdmin() && sameTenantOnCreate();
      allow update: if (isOwner(resource.data.userId) && sameTenant(resource.data))
        || (isOperatorOrAdmin() && sameTenant(resource.data));
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== VEHICULOS =====
    match /vehicles/{vehicleId} {
      allow read: if isActive() && sameTenant(resource.data);
      allow create: if isOperatorOrAdmin() && sameTenantOnCreate();
      allow update: if (isOwner(resource.data.driverId) && sameTenant(resource.data))
        || (isAdmin() && sameTenant(resource.data));
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== VIAJES =====
    // Lectura RESTRINGIDA: una carrera asignada solo la ven admin/operadora
    // del tenant y el conductor asignado (dueño). El resto de conductores
    // activos NO ven carreras ajenas.
    match /trips/{tripId} {
      allow read: if sameTenant(resource.data)
        && (isOperatorOrAdmin() || isOwner(resource.data.driverId));
      allow create: if isOperatorOrAdmin() && sameTenantOnCreate();
      allow update: if (isOwner(resource.data.driverId) && sameTenant(resource.data))
        || (isOperatorOrAdmin() && sameTenant(resource.data));
      allow delete: if isAdmin() && sameTenant(resource.data);

      // Historial de reasignaciones (auditoría): quién pasó la carrera de un
      // conductor a otro, cuándo y quién lo hizo. Las reglas NO cascadean a
      // subcolecciones, por eso se declara explícitamente. Inmutable.
      match /reassignments/{rid} {
        allow read: if isActive()
          && sameTenant(get(/databases/$(database)/documents/trips/$(tripId)).data);
        allow create: if isOperatorOrAdmin() && sameTenantOnCreate();
        allow update, delete: if false;
      }
    }

    // ===== PAGOS =====
    // - Conductor: ve los suyos y crea reportes propios (estado pending).
    //   Si está paymentBlocked, AÚN puede subir comprobante (es la única
    //   acción permitida cuando está bloqueado por mora).
    // - Operadora/admin: ven todos los del tenant y validan/rechazan.
    match /payments/{paymentId} {
      allow read: if canSubmitPayment() && (
        isOwner(resource.data.driverId) || isOperatorOrAdmin()
      ) && sameTenant(resource.data);

      allow create: if sameTenantOnCreate() && (
        // Conductor reporta su propio pago (incluso si paymentBlocked).
        (canSubmitPayment() && isOwner(request.resource.data.get('driverId', '')))
        || isOperatorOrAdmin()
      );

      allow update: if sameTenant(resource.data) && (
        (canSubmitPayment() && isOwner(resource.data.driverId))
        || isOperatorOrAdmin()
        || (isAdmin() && _isVoidUpdate())
      );

      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== PERMISOS (conductor que avisa que no trabaja X días) =====
    // - Lectura: el dueño del permiso O cualquier admin/operadora del
    //   tenant (necesario para mostrarlo en el cierre semanal).
    // - Crear/actualizar: solo admin/operadora del tenant.
    match /permissions/{permissionId} {
      allow read: if canSubmitPayment() && sameTenant(resource.data) && (
        isOwner(resource.data.driverId) || isOperatorOrAdmin()
      );
      allow create: if isOperatorOrAdmin() && sameTenantOnCreate();
      allow update: if isOperatorOrAdmin() && sameTenant(resource.data);
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== GASTOS =====
    match /expenses/{expenseId} {
      allow read: if isActive() && sameTenant(resource.data) && (
        isOwner(resource.data.driverId) || isOperatorOrAdmin()
      );
      allow create: if isActive() && sameTenantOnCreate()
        && request.resource.data.driverId == request.auth.uid;
      allow update: if isActive() && sameTenant(resource.data) && (
        isOwner(resource.data.driverId) || isAdmin()
      );
      allow delete: if isActive() && sameTenant(resource.data) && (
        isOwner(resource.data.driverId) || isAdmin()
      );
    }

    // ===== CANALES (Walkie-Talkie) =====
    // - Públicos: todos los del tenant que estén operativos.
    // - Privados: solo si el usuario está en memberIds o es operador/admin.
    match /channels/{channelId} {
      allow read: if canOperate() && sameTenant(resource.data) && (
        resource.data.get('type', 'publico') == 'publico'
        || isOperatorOrAdmin()
        || (request.auth.uid in resource.data.get('memberIds', []))
      );
      allow create: if isOperatorOrAdmin() && sameTenantOnCreate();

      allow update: if sameTenant(resource.data) && (
        isAdmin()
        || _canModerateChannel()  // operadora/admin con status active o paymentPending
        || _isPttLockUpdate()
        || _isMemberIdsSelfUpdate()
      );

      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    /// Operadora/admin puede moderar (cambiar miembros, defaults, type)
    /// del canal incluso si está en paymentPending (igual que canOperate).
    /// Antes la regla pedía isActive() y, si el JWT estaba un poco
    /// desactualizado o el rol caía a paymentPending por algún ciclo de
    /// pago, la op no podía activar/desactivar conductores en el radio.
    function _canModerateChannel() {
      return canOperate() && getRole() in ['admin', 'operadora'];
    }

    function _isPttLockUpdate() {
      return canOperate()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['currentSpeakerId', 'currentSpeakerName', 'speakerLockedAt'])
        && _isValidLockTransition();
    }

    function _isValidLockTransition() {
      let newSpeaker = request.resource.data.get('currentSpeakerId', null);
      let oldSpeaker = resource.data.get('currentSpeakerId', null);

      let isTake = newSpeaker == request.auth.uid
        && pttLockAvailable(resource.data)
        && request.resource.data.currentSpeakerName is string
        && request.resource.data.speakerLockedAt == request.time;

      // Release válido si: el speaker se libera a sí mismo, el lock
      // expiró por timeout, o un admin/operadora desbloquea a otro
      // (caso "PTT pegado" — desatasca el canal para todos).
      let isRelease = newSpeaker == null
        && request.resource.data.get('currentSpeakerName', null) == null
        && request.resource.data.get('speakerLockedAt', null) == null
        && (
          oldSpeaker == request.auth.uid
          || pttLockExpired(resource.data)
          || _canModerateChannel()
        );

      return isTake || isRelease;
    }

    function _isMemberIdsSelfUpdate() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return canOperate()
        && keys.hasOnly(['memberIds'])
        && (
          isOperatorOrAdmin()
          || (
            !(request.auth.uid in resource.data.memberIds)
            && request.auth.uid in request.resource.data.memberIds
          )
          || (
            request.auth.uid in resource.data.memberIds
            && !(request.auth.uid in request.resource.data.memberIds)
          )
        );
    }

    function _isVoidUpdate() {
      return resource.data.status == 'validated'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['voidedAt', 'voidedBy', 'voidReason'])
        && request.resource.data.voidReason is string
        && request.resource.data.voidReason.size() >= 10;
    }

    // ===== MENSAJES DE CANAL (top-level, walkie-talkie) =====
    // El canal pertenece al tenant. Validamos que el sender sea del mismo
    // tenant que el canal y miembro/admin para escribir.
    //
    // canOperate() incluye paymentPending → un conductor en período de
    // gracia puede seguir hablando por el radio. Solo paymentBlocked y
    // disabledByAdmin quedan fuera (correctamente — no operan).
    match /messages/{messageId} {
      allow read: if canOperate() && sameTenant(resource.data);

      allow create: if canOperate()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.channelId is string
        && sameTenantOnCreate();

      allow update: if false;
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== CHAT ROOMS =====
    // Permanece basado en participantIds (no por tenant); un room privado
    // 1-a-1 entre usuarios del mismo tenant es la práctica normal.
    match /chat_rooms/{roomId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in
              get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.participantIds;
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in
              get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.participantIds;
        allow update: if isAuthenticated()
          && request.auth.uid in
              get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.participantIds
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
        allow delete: if false;
      }
    }

    // ===== ASSOCIATION GROUP CHAT =====
    match /associationChats/{aid}/groupMessages/{msgId} {
      allow read: if isAuthenticated() && myAssociationId() == aid;
      allow create: if isAuthenticated()
        && myAssociationId() == aid
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
      allow update, delete: if false; // inmutable; purga por Admin SDK
    }

    // ===== EMERGENCIAS =====
    match /emergencies/{emergencyId} {
      allow read: if isActive() && sameTenant(resource.data);
      allow create: if isActive() && sameTenantOnCreate()
        && request.resource.data.driverId == request.auth.uid;
      allow update: if isActive() && sameTenant(resource.data) && (
        isOwner(resource.data.driverId) || isOperatorOrAdmin()
      );
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== COMPETITOR TRIPS =====
    match /competitor_trips/{tripId} {
      allow read: if isActive() && sameTenant(resource.data);
      allow create: if isOperatorOrAdmin() && sameTenantOnCreate();
      allow update: if isOperatorOrAdmin() && sameTenant(resource.data);
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== PARADAS DE TAXI =====
    match /taxi_stands/{standId} {
      allow read: if isActive() && sameTenant(resource.data);
      allow create: if isOperatorOrAdmin() && sameTenantOnCreate();
      allow update: if isOperatorOrAdmin() && sameTenant(resource.data);
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== INCENTIVOS =====
    match /incentives/{incentiveId} {
      allow read: if isActive() && sameTenant(resource.data);
      allow create: if isAdmin() && sameTenantOnCreate();
      allow update: if isAdmin() && sameTenant(resource.data);
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== CASHFLOW (ingresos/egresos del admin) =====
    // Solo admin del tenant puede leer/escribir. Operadoras NO ven números.
    match /cashflow/{movId} {
      allow read: if (isAdmin() || isSuperAdmin()) && sameTenant(resource.data);
      allow create: if isAdmin() && sameTenantOnCreate();
      allow update: if isAdmin() && sameTenant(resource.data);
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== MÉTRICAS DE OPERADORA (asignaciones diarias) =====
    // Lectura: operadora dueña + admins del tenant. Escritura: la propia
    // operadora cuando asigna una carrera (FieldValue.increment).
    match /operadora_metrics/{metricId} {
      allow read: if sameTenant(resource.data) && (
        isOperatorOrAdmin() || isOwner(resource.data.operatorId)
      );
      allow create, update: if isActive() && sameTenantOnCreate()
        && request.resource.data.operatorId == request.auth.uid;
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== NOTIFICACIONES (admin → conductores/operadoras) =====
    // Documentos creados por admins; cualquier autenticado del mismo
    // tenant puede leerlas (filtradas por audiencia en cliente).
    match /notifications/{notifId} {
      allow read: if isActive() && sameTenant(resource.data);
      allow create: if isAdmin() && sameTenantOnCreate();
      allow update: if isAdmin() && sameTenant(resource.data);
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== EVENTOS DE QUITO (cron Gemini, lectura pública) =====
    // Compartidos entre asociaciones — solo lectura para autenticados.
    // Escritura: solo Cloud Functions (admin SDK) o super-admin.
    match /eventsQuito/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ===== SOLICITUDES DE CARRERA (clientes web + operadora) =====
    // - Cliente autenticado: crea solicitudes propias (clienteId==uid)
    //   y lee/cancela las suyas.
    // - Operadora/admin del tenant: ve todas, asigna, actualiza estado.
    function isClienteOf(data) {
      return isAuthenticated()
        && data.get('clienteId', '') == request.auth.uid;
    }
    match /tripRequests/{reqId} {
      // Lectura: dentro del tenant la ven operadora/admin y los conductores
      // activos (para listar las "por asignar"; el filtro fino lo hace la
      // app). El cliente dueño SIEMPRE ve la suya (para su "mis-carreras"
      // web), aunque no sea active.
      allow read: if (sameTenant(resource.data) && (isOperatorOrAdmin() || isActive()))
        || isClienteOf(resource.data);
      allow create: if (isOperatorOrAdmin() && sameTenantOnCreate())
        || (
          isAuthenticated()
          && request.resource.data.get('clienteId', '') == request.auth.uid
          && request.resource.data.get('associationId', '') is string
          && request.resource.data.get('estado', '') == 'pendiente'
        );
      allow update: if (isOperatorOrAdmin() && sameTenant(resource.data))
        // El cliente dueño solo puede cancelar su propia solicitud.
        || (
          isClienteOf(resource.data)
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['estado', 'updatedAt'])
          && request.resource.data.estado == 'cancelada'
        )
        // El cliente dueño califica SOLO cuando la carrera ya finalizó, y
        // solo puede tocar los campos de rating. Rango 1..5.
        || (
          isClienteOf(resource.data)
          && resource.data.estado == 'finalizada'
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['rating', 'ratingComment', 'ratedAt'])
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
        );
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== CLIENTES (perfil del cliente web) =====
    // Doc en `clients/{uid}` con datos de contacto del cliente final.
    // Cada cliente solo puede leer/escribir el suyo. Operadora/admin
    // de cualquier asociación pueden leerlos para mostrar info en la
    // app móvil cuando llega una solicitud.
    match /clients/{uid} {
      allow read: if isOwner(uid) || isOperatorOrAdmin();
      allow create, update: if isOwner(uid);
      allow delete: if isOwner(uid) || isSuperAdmin();
    }

    // ===== CAMBIOS DE UNIDAD =====
    // - Lectura: el dueño del request O admin/operadora del mismo tenant.
    // - Creación: solo el conductor crea su propio request.
    // - Update y delete: solo vía Cloud Functions (Admin SDK bypasea reglas).
    match /vehicleChangeRequests/{reqId} {
      allow read: if isAuthenticated() && (
        (resource.data.driverId == request.auth.uid)
        || (isOperatorOrAdmin() && sameTenant(resource.data))
      );

      allow create: if isActive()
        && request.resource.data.driverId == request.auth.uid
        && sameTenantOnCreate();

      allow update: if false;
      allow delete: if isAdmin() && sameTenant(resource.data);
    }

    // ===== ANALYTICS (precomputado por cron, solo admin del tenant lo lee) =====
    match /analytics/{analyticsId} {
      allow read: if (isAdmin() || isSuperAdmin()) && sameTenant(resource.data);
      allow write: if isSuperAdmin();
    }

    // ===== ESTADÍSTICAS DIARIAS DE CARRERAS (agregados por asociación) =====
    // Doc id = `${associationId}_${YYYY-MM-DD}`. Contiene SOLO agregados
    // (carreras por hora + estimado monetario), sin datos personales de
    // otros conductores. Los escribe EXCLUSIVAMENTE una Cloud Function
    // (Admin SDK, que bypasea estas reglas).
    // - Lectura: cualquier usuario activo del mismo tenant (incluido el
    //   conductor) puede leer el agregado de SU asociación, para comparar
    //   su reporte contra "la base" sin leer carreras ajenas. El doc trae
    //   `associationId`, por lo que sameTenant(resource.data) aplica.
    // - Escritura: nadie desde el cliente; solo la Cloud Function.
    match /tripStatsDaily/{statId} {
      allow read: if isActive() && sameTenant(resource.data);
      allow write: if false; // solo Cloud Functions (admin SDK)
    }

    // Agregado diario POR CONDUCTOR: lo lee el propio conductor (su reporte
    // personal) y el admin/operadora de la misma asociación (productividad).
    match /driverStatsDaily/{statId} {
      allow read: if sameTenant(resource.data)
        && (isOperatorOrAdmin() || isOwner(resource.data.driverId));
      allow write: if false; // solo Cloud Functions (admin SDK)
    }

    // Embudo diario de solicitudes web (calidad de servicio): lo leen
    // admin/operadora de la asociación. Escritura solo Cloud Functions.
    match /tripRequestStatsDaily/{statId} {
      allow read: if isActive() && sameTenant(resource.data);
      allow write: if false;
    }

    // ===== APP CONFIG (versionamiento por plataforma) =====
    // Doc por plataforma: `app_config/android`, `app_config/ios`.
    // Estructura:
    //   { minRequiredBuild, latestBuild, storeUrl, message, updatedAt }
    // - Lectura: cualquier autenticado (la necesita el VersionGateService
    //   en el boot, ANTES de saber el rol del usuario).
    // - Escritura: solo super-admin (publica nuevas versiones).
    // Flag de logging remoto (diagnóstico): lo lee cualquier autenticado
    // (gate del envío de logs) y lo activa/desactiva el ADMIN desde el toggle
    // de la app. Match específico ANTES del general para no aflojar el resto
    // de app_config (versiones), que sigue siendo solo super-admin.
    match /app_config/remoteLogging {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }
    match /app_config/{platform} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
  }
}
