<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permisos de Internet -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Permisos de Ubicacion (GPS tracking, mapa) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>

    <!-- Permisos de Microfono (walkie-talkie PTT) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>

    <!-- Bluetooth (audio por auriculares bluetooth) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>

    <!-- Permisos de Notificaciones (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Permisos de Vibracion (emergencia/alarma) -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- Foreground service para ubicacion en segundo plano -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>

    <!-- Foreground service para radio/walkie-talkie en segundo plano -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

    <!-- Wake lock para mantener PTT activo -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- Overlay: botón PTT flotante sobre todas las apps -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <application
        android:label="Taxi Jipijapa"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!-- Google Maps API Key (inyectada desde local.properties / CI secret) -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${GOOGLE_MAPS_API_KEY}"/>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Foreground Service compartido (radio + ubicación) en segundo plano.
             foregroundServiceType="location|mediaPlayback":
              - location: necesario para que Android NO throttlee el GPS ni
                congele el socket WebRTC mientras la app está en background
                (sin location, el conductor desaparecía del mapa a los ~6 min).
              - mediaPlayback: mantiene el audio entrante del radio reproduciéndose.
             El "tag" de microphone se quitó intencionalmente para que otras apps
             (Zello/WhatsApp/grabadora) NO vean el mic ocupado cuando el radio está
             ON pero el conductor no está presionando PTT.

             ⚠️ ANTI-CRASH: con el tipo `location` declarado, arrancar este FGS sin
             el permiso de ubicación concedido CRASHEA en Android 14+. Por eso
             RadioForegroundService verifica `Permission.locationWhenInUse` ANTES
             de startService (ver _ensureRunning).

             Trade-off: el PTT en background sin overlay flotante NO funciona
             (Android 14+ requiere foreground service tipo microphone para
             capturar el mic en background). Cuando el conductor quiere PTT en
             background debe activar el overlay flotante (que SÍ tiene microphone). -->
        <service
            android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
            android:foregroundServiceType="location|mediaPlayback"
            android:exported="false" />

        <!-- Overlay PTT: botón flotante sobre todas las apps. Declara
             AMBOS tipos (microphone | mediaPlayback) y alterna en runtime:
              - Idle  → mediaPlayback: el mic queda libre para WhatsApp,
                        Zello, grabadora, etc.
              - PTT pressed → microphone: la app reclama el mic para
                        transmitir.
             El switch se hace con startForeground(id, notif, type). -->
        <service
            android:name=".OverlayPttService"
            android:foregroundServiceType="microphone|mediaPlayback"
            android:exported="false" />

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
